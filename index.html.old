      color: #0092d2;
    }
    .compas-jumbotron {
      background-color: #000;
      background-image: url(images/compas_screenshot.jpg);
      background-position: 50% 50%;
      background-repeat: no-repeat;
      background-size: 1140px;
      height: 480px
