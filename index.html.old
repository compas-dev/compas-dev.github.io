  <!-- 

    * Why COMPAS => description + overview of main components
    * Getting started & Tutorial button in jumbotron
    * Use cases / Testimonials
    * Icons of contributors (like sponsors, users)
    * Supporting institutes
    * Keywords: parametric/design/geometry/mesh processing (ask other devs)?
    * Develop across platforms
    * Refer to roadmap for details of future developments

  -->

  <main>
    <section class="jumbotron compas-jumbotron text-center m-0 mt-5 pb-5">
      <div class="container">
        <div class="row w-50 mx-auto mb-3 align-items-center">
          <div class="col-12 col-md-8 order-md-2">
            <h1 class="d-none">COMPAS</h1>
            <p class="d-none lead">
              A computational framework for research and collaboration in the AE(F)C industry.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Overview -->
    <div class="overview bg-light py-5">
      <!-- Container -->
      <div class="container">

        <!-- Research in AEFC -->
        <section class="text-center">
          <div class="row">
            <div class="col py-5">
              <h2 class="display-4 text-black-50 pb-3">Research & Collaboration</h2>
              <p class="lead text-muted w-75 mx-auto">
                COMPAS is an open source, python-based framework for computational research and collaboration in architecture, engineering, fabrication and construction (AEFC).
              </p>
              <!-- Redesign to reflect Core + Core extensions (NCCR) + Research packages -->
              <img class="card-img w-75 mx-auto mb-3" src="images/COMPAS_ecosystem.png"  alt="" />
            </div>
          </div>
        </section>
        <!-- Research in AEFC -->

        <!-- Core functionality -->
        <section class="text-center">
          <div class="row">
            <div class="col py-5">
              <h2 class="display-4 text-black-50 pb-3">Core Functionality</h2>
              <p class="lead text-muted w-75 mx-auto">
                ...
              </p>
              <div class="row pt-5 pb-5">
                <!-- Geometry Processing -->
                <div class="col-12 col-md-4 mx-auto">
                  <div class="card">
                    <div class="card-body">
                      <h4 class="card-title font-weight-normal">Geometry Processing</h4>
                      <p class="card-text text-muted"></p>
                    </div>
                  </div>
                </div>
                <!-- Geometry Processing -->
                <!-- Data Structures -->
                <div class="col-12 col-md-4 mx-auto">
                  <div class="card">
                    <div class="card-body">
                      <h4 class="card-title font-weight-normal">Data Structures</h4>
                      <p class="card-text text-muted"></p>
                    </div>
                  </div>
                </div>
                <!-- Data Structures -->
                <!-- Robot Fundamentals -->
                <div class="col-12 col-md-4 mx-auto">
                  <div class="card">
                    <div class="card-body">
                      <h4 class="card-title font-weight-normal">Robot Fundamentals</h4>
                      <p class="card-text text-muted"></p>
                    </div>
                  </div>
                </div>
                <!-- Robot Fundamentals -->
              </div>
            </div>
          </div>
        </section>
        <!-- Core functionality -->

        <!-- CAD Integration -->
        <section class="text-center">
          <div class="row">
            <div class="col py-5">
              <h2 class="display-4 text-black-50 pb-3">CAD Integration</h2>
              <p class="lead text-muted w-75 mx-auto">
                CAD tools are everywhere in the AEFC industry, both in research and in practice.
                COMPAS simplifies ...
              </p>
              <!-- Snippets -->
              <div class="row py-5">
                <!-- Rhino -->
                <div class="col-12 col-md-6 mb-4">
                  <div class="card bg-white border-1 shadow-lg">
                    <div class="card-body">
                      <h3 class="card-title">Rhino</h3>
                      <pre class="text-left">
<code class="python bg-white">
import compas

from compas.datastructures import Mesh
from compas_rhino.artists import MeshArtist

mesh = Mesh.from_obj(compas.get('tubemesh.obj'))

artist = MeshArtist(mesh)
artist.draw_vertices()
artist.draw_faces()
artist.draw_edges()
</code>
                      </pre>
                    </div>
                  </div>
                </div>
                <!-- Rhino -->
                <!-- Blender -->
                <div class="col-12 col-md-6 mb-4">
                  <div class="card bg-white border-1 shadow-lg">
                    <div class="card-body">
                      <h3 class="card-title">Blender</h3>
                      <pre class="text-left">
<code class="python bg-white">
import compas

from compas.datastructures import Mesh
from compas_blender.artists import MeshArtist

mesh = Mesh.from_obj(compas.get('tubemesh.obj'))

artist = MeshArtist(mesh)
artist.draw_vertices()
artist.draw_faces()
artist.draw_edges()
</code>
                      </pre>
                    </div>
                  </div>
                </div>
                <!-- Blender -->
              </div>
              <!-- Snippets -->
            </div>
          </div>
        </section>
        <!-- CAD Integration -->

        <!-- Extensions -->
        <section class="text-center">
          <div class="row">
            <div class="col py-5">
              <h2 class="display-4 text-black-50 pb-3">Extensions</h2>
              <p class="lead text-muted w-75 mx-auto">
                The core components of COMPAS can be easily extended
                with AEFC packages developed by the <a href="https://www.dfab.ch" target="_blank">NCCR Digital Fabrication</a> at ETH Zurich.
              </p>

              <!-- Packages -->
              <div class="row py-5 text-left">
                <!-- compas_fab -->
                <div class="col-12 col-md-4 d-flex mb-4">
                  <div class="card bg-white flex-even">
                    <div class="card-header bg-white">
                      <img src="images/compas_fab_img_1800.png" alt="compas_fab" class="card-img-top" />
                    </div>
                    <div class="card-body bg-white">
                      <h4 class="card-title font-weight-normal"><a href="https://gramaziokohler.github.io/compas_fab/latest/" target="_blank" class="card-link">compas_fab</a></h4>
                      <p class="card-text text-muted">Robotic fabrication package providing interface to ROS.</p>
                    </div>
                  </div>
                </div>
                <!-- compas_fab -->
                <!-- compas_fea -->
                <div class="col-12 col-md-4 d-flex mb-4">
                  <div class="card bg-white flex-even">
                    <div class="card-header bg-white">
                      <img src="images/compas_fea.png" alt="compas_fea" class="card-img-top" />
                    </div>
                    <div class="card-body bg-white">
                      <h4 class="card-title font-weight-normal"><a href="https://compas-dev.github.io/compas_fea/" target="_blank" class="card-link">compas_fea</a></h4>
                      <p class="card-text text-muted">Finite Element Analysis using Ababqus, Ansys, Sofistik or OpenSEES.</p>
                    </div>
                  </div>
                </div>
                <!-- compas_fea -->
                <!-- compas_vol -->
                <div class="col-12 col-md-4 d-flex mb-4">
                  <div class="card bg-white flex-even">
                    <div class="card-header bg-white">
                      <img src="images/compas_vol.png" alt="compas_tna" class="card-img-top" />
                    </div>
                    <div class="card-body bg-white">
                      <h4 class="card-title font-weight-normal"><a href="https://dbt-ethz.github.io/compas_vol/" target="_blank" class="card-link">compas_vol</a></h4>
                      <p class="card-text text-muted">Volumetric modelling of 3D geometry using signed distance functions.</p>
                    </div>
                  </div>
                </div>
                <!-- compas_vol -->
              </div>
              <!-- Packages -->
            </div>
          </div>
        </section>
        <!-- Extensions -->

        <!-- Cross platform -->
        <section class="text-center">
          <div class="row">
            <div class="col py-5">
              <h2 class="display-4 text-black-50 pb-3">Cross Platform</h2>
              <p class="lead text-muted w-75 mx-auto mb-5">
                COMPAS is written in Python and can be easily installed using popular package managers on multiple platforms.
              </p>
              <p class="lead text-muted w-75 mx-auto">
                <span class="fab fa-windows fa-3x mx-3"></span>
                <span class="fab fa-apple fa-3x mx-3"></span>
                <span class="fab fa-linux fa-3x mx-3"></span>
              </p>
              <!-- Shell session -->
              <div class="row pt-5 pb-5">
                <div class="col col-md-8 mx-auto">
                  <div class="card bg-dark">
                    <div class="card-body">
                      <pre class="text-left">
<code class="plaintext bg-dark text-light">
$ conda create -n compas-dev python=3.7 COMPAS
$ conda activate compas-dev
$ python
Python 3.7.1 (default, Dec 14 2018, 13:28:58) 
[Clang 4.0.1 (tags/RELEASE_401/final)] :: Anaconda, Inc. on darwin
Type "help", "copyright", "credits" or "license" for more information.
>>> import compas</code>
                      </pre>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Shell session -->
            </div>
          </div>
        </section>
        <!-- Cross platform -->

        <!-- Flexibility -->
        <section class="text-center">
          <div class="row">
            <div class="col py-5">
              <h2 class="display-4 text-black-50 pb-3">Flexibility</h2>
              <p class="lead text-muted w-75 mx-auto mb-5">
                ...
              </p>
              <div class="row pt-5 pb-5">
                <!-- File formats -->
                <div class="col-12 col-md-4 mx-auto">
                  <div class="card">
                    <div class="card-body">
                      <h4 class="card-title font-weight-normal">File formats</h4>
                      <p class="card-text text-muted"></p>
                    </div>
                  </div>
                </div>
                <!-- File formats -->
                <!-- Serialisation -->
                <div class="col-12 col-md-4 mx-auto">
                  <div class="card">
                    <div class="card-body">
                      <h4 class="card-title font-weight-normal">Serialisation</h4>
                      <p class="card-text text-muted"></p>
